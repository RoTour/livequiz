      "boundElements": [],
      "updated": 1760000000014,
      "link": null,
      "locked": false,
      "text": "4) Writes student_identities (email, status=REGISTERED_UNVERIFIED)\n5) Writes email_verification_challenges (token_hash, expires_at)",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4) Writes student_identities (email, status=REGISTERED_UNVERIFIED)\n5) Writes email_verification_challenges (token_hash, expires_at)",
      "lineHeight": 1.25,
      "autoResize": false
    },
    {
      "id": "verify-flow",
      "type": "text",
      "x": 290,
      "y": 740,
      "width": 900,
      "height": 170,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1015,
      "version": 1,
      "versionNonce": 2015,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760000000015,
      "link": null,
      "locked": false,
      "text": "6) Student opens verification link, POST /api/auth/students/verify-email {token}\n7) Backend hashes token, finds latest challenge, validates not expired/not consumed\n8) Backend marks challenge consumed + sets student status REGISTERED_VERIFIED\n9) Backend returns new JWT(subject=studentId, email_verified=true)",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "6) Student opens verification link, POST /api/auth/students/verify-email {token}\n7) Backend hashes token, finds latest challenge, validates not expired/not consumed\n8) Backend marks challenge consumed + sets student status REGISTERED_VERIFIED\n9) Backend returns new JWT(subject=studentId, email_verified=true)",
      "lineHeight": 1.25,
      "autoResize": false
    },
    {
      "id": "no-password-note",
      "type": "text",
