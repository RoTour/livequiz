      "boundElements": [],
      "updated": 1760000000016,
      "link": null,
      "locked": false,
      "text": "Important: students do not have passwords in DB; only verification token hashes are stored.",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Important: students do not have passwords in DB; only verification token hashes are stored.",
