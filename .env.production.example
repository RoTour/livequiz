# Copy this file to .env.production and replace all placeholder values.

# --- Database ---
POSTGRES_DB=livequiz
POSTGRES_USER=livequiz_app
POSTGRES_PASSWORD=replace-with-strong-random-password

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=livequiz_mq
RABBITMQ_DEFAULT_PASS=replace-with-strong-random-password
RABBITMQ_DEFAULT_VHOST=livequiz

# --- JWT and core app ---
LIVEQUIZ_JWT_SECRET=replace-with-long-random-secret-min-32-bytes
LIVEQUIZ_INVITE_BASE_URL=https://livequiz.rotour.dev/student/join
LIVEQUIZ_STUDENT_EMAIL_VERIFICATION_URL_BASE=https://livequiz.rotour.dev/student/verify-email
LIVEQUIZ_STUDENT_EMAIL_ALLOWED_DOMAIN=ynov.com

# --- SMTP (AWS SES) ---
LIVEQUIZ_STUDENT_EMAIL_VERIFICATION_FROM=no-reply@your-domain.com
SPRING_MAIL_HOST=email-smtp.eu-west-1.amazonaws.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=replace-with-ses-smtp-username
SPRING_MAIL_PASSWORD=replace-with-ses-smtp-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# --- Messaging quotas ---
LIVEQUIZ_EMAIL_SES_MAX_PER_SECOND=1
LIVEQUIZ_EMAIL_SES_MAX_PER_DAY=200

# --- Optional tuning ---
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
TZ=UTC
