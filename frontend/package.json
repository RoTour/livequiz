{
  "name": "livequiz-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "./scripts/with-node.sh ./node_modules/.bin/ng",
    "start": "./scripts/with-node.sh ./node_modules/.bin/ng serve",
    "build": "./scripts/with-node.sh ./node_modules/.bin/ng build",
    "watch": "./scripts/with-node.sh ./node_modules/.bin/ng build --watch --configuration development",
    "test": "./scripts/with-node.sh ./node_modules/.bin/ng test",
    "test:coverage": "./scripts/with-node.sh ./node_modules/.bin/ng test --watch=false --coverage",
    "test:mutation": "stryker run"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.4.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "qrcode": "^1.5.4",
    "@tailwindcss/postcss": "^4.1.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@types/qrcode": "^1.5.5",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
